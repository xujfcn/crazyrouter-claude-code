# Crazyrouter Configuration for Claude Code
# Get your API key at https://crazyrouter.com

# Anthropic-compatible endpoint (best for Claude-native tools)
ANTHROPIC_BASE_URL=https://crazyrouter.com
ANTHROPIC_AUTH_TOKEN=sk-your-crazyrouter-key

# OpenAI-compatible endpoint (useful for other coding tools too)
OPENAI_API_KEY=sk-your-crazyrouter-key
OPENAI_BASE_URL=https://crazyrouter.com/v1

# Optional: default Claude model
# Examples (2026-03):
# CLAUDE_MODEL=claude-sonnet-4
# CLAUDE_MODEL=claude-opus-4-6
# CLAUDE_MODEL=claude-haiku-3.5
